#!/usr/bin/env python3
"""
Simple HTTP server for static concert tickets application
Serves on 0.0.0.0:8000 to be accessible from anywhere
"""

import http.server
import socketserver
import os

PORT = 8000
DIRECTORY = "static"

class Handler(http.server.SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=DIRECTORY, **kwargs)

def run_server():
    os.chdir(os.path.dirname(os.path.abspath(__file__)))
    
    with socketserver.TCPServer(("0.0.0.0", PORT), Handler) as httpd:
        print(f"Serving concert tickets app at http://0.0.0.0:{PORT}")
        print(f"Access from: http://localhost:{PORT} or http://<your-ip>:{PORT}")
        print("Press Ctrl+C to stop")
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            print("\nServer stopped.")
            httpd.shutdown()

if __name__ == "__main__":
    run_server()
